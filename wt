#!/usr/bin/env bash
set -euo pipefail

# --- styling ---
G=$'\033[1;32m'; Y=$'\033[1;33m'; C=$'\033[1;36m'; R=$'\033[1;31m'
D=$'\033[2m';    B=$'\033[1m';    N=$'\033[0m'

ok()   { printf '%s✓%s %s\n' "$G" "$N" "$*"; }
info() { printf '%s→%s %s\n' "$Y" "$N" "$*"; }
err()  { printf '%s✗%s %s\n' "$R" "$N" "$*" >&2; }

# --- fzf common styling ---
FZF_OPTS=(
  --border=rounded --border-label=' wt '
  --prompt='❯ ' --pointer='▌' --marker='✓'
  --color='hl+:cyan,pointer:green,marker:green,header:dim,label:cyan'
)

fzf_pick() { fzf --height=~40% "${FZF_OPTS[@]}" "$@"; }

usage() {
  cat <<EOF
${B}wt${N} — interactive git worktree manager

${B}Usage:${N} wt [command]

${B}Commands:${N}
  (none)    show menu (add / go / remove / list)
  add       add a new worktree interactively
  go        pick a worktree and print its path (for cd)
  ls, list  list worktrees for this repo
  rm [name] remove a worktree (interactive or by partial name)

${B}Options (add):${N}
  -n, --no-env       skip copying .env* files from main checkout
  -c, --copy <glob>  glob pattern to copy from main checkout (default: .env*)

${B}Shell integration:${N}
  alias wtgo='cd \$(wt go)'
EOF
  exit 0
}

# --- commands ---

cmd_menu() {
  require_fzf
  local choice
  choice=$(printf 'Add\tcreate a new worktree\nGo\tjump to existing worktree\nRemove\tdelete a worktree\nList\tshow all worktrees' \
    | fzf --height=~30% --header='pick an action' "${FZF_OPTS[@]}" \
    | cut -f1)
  case "$choice" in
    Add)    cmd_add ;;
    Go)     cmd_go ;;
    Remove) cmd_remove "" ;;
    List)   cmd_list ;;
  esac
}

cmd_add() {
  local copy_env=true copy_glob=".env*"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n|--no-env) copy_env=false; shift ;;
      -c|--copy)   copy_glob="$2"; shift 2 ;;
      *) err "unknown option: $1"; usage ;;
    esac
  done

  resolve_wt_root

  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "not in a git repository"
    exit 1
  }
  REPO_NAME=$(basename "$REPO_ROOT")

  # Background fetch: UI is not blocked on network; picker uses last-known refs.
  git fetch origin >/dev/null 2>&1 & disown

  local branches
  branches=$(git branch -r --format='%(refname:short)' \
    | sed 's|^origin/||' \
    | grep -v '^HEAD$' \
    | sort -u)

  if [ -z "$branches" ]; then
    err "no remote branches found"
    exit 1
  fi

  require_fzf

  local branch
  branch=$(printf '%s\n' "$branches" \
    | fzf_pick --header="$REPO_NAME — pick a branch" \
               --preview='git log -1 --oneline origin/{1} --color=always 2>/dev/null || echo "no commits"' )

  if [ -z "$branch" ]; then
    err "no branch selected"
    exit 0
  fi

  local WORKTREE_PATH="$WT_ROOT/$REPO_NAME/$branch"

  if [ -d "$WORKTREE_PATH" ]; then
    err "worktree already exists at $WORKTREE_PATH"
    exit 1
  fi

  info "creating worktree: $WORKTREE_PATH"
  git worktree add "$WORKTREE_PATH" "$branch"

  if $copy_env; then
    shopt -s nullglob
    local -a copy_files=("$REPO_ROOT"/$copy_glob)
    if [ ${#copy_files[@]} -gt 0 ]; then
      info "copying $copy_glob files..."
      cp "$REPO_ROOT"/$copy_glob "$WORKTREE_PATH/"
      printf '  %scopied %d file(s)%s\n' "$D" "${#copy_files[@]}" "$N"
    fi
  fi

  ok "done: $WORKTREE_PATH"
  printf '%s' "$WORKTREE_PATH" | pbcopy 2>/dev/null \
    && printf '  %s(path copied to clipboard)%s\n' "$D" "$N" \
    || true
}

cmd_go() {
  require_fzf
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "not in a git repository"
    exit 1
  }
  local path
  path=$(get_worktrees "$REPO_ROOT" \
    | fzf_pick --header='enter to print path' \
               --preview='git -C {2} log -1 --oneline --color=always 2>/dev/null || echo "no commits"' \
    | cut -f2)
  [ -n "$path" ] && printf '%s' "$path"
}

cmd_list() {
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "not in a git repository"
    exit 1
  }
  git worktree list --porcelain | awk -v main="$REPO_ROOT" '
    /^worktree/ { path=$2 }
    /^branch/   { branch=$2; gsub(/^refs\/heads\//, "", branch) }
    /^HEAD/     { head=substr($2,1,7) }
    /^$/ {
      if (path == main)
        printf "●  \033[1;32m%-30s\033[0m  \033[2m%s  %s\033[0m\n", branch, head, path
      else
        printf "○  %-30s  \033[2m%s  %s\033[0m\n", branch, head, path
      path=branch=head=""
    }'
}

cmd_remove() {
  require_fzf
  local target="$1"

  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "not in a git repository"
    exit 1
  }

  local worktrees
  worktrees=$(get_worktrees "$REPO_ROOT")

  if [ -z "$worktrees" ]; then
    err "no worktrees to remove"
    exit 0
  fi

  if [ -z "$target" ]; then
    target=$(echo "$worktrees" \
      | fzf_pick --header='pick a worktree to remove' \
                 --preview='git -C {2} log -1 --oneline --color=always 2>/dev/null || echo "no commits"' \
      | cut -f2)
  else
    target=$(echo "$worktrees" | grep "$target" | head -1 | cut -f2)
  fi

  if [ -z "$target" ]; then
    err "no worktree selected"
    exit 0
  fi

  info "removing: $target"
  git worktree remove "$target" || {
    err "remove failed (uncommitted changes?). Use --force to override."
    exit 1
  }
  ok "removed"
}

# --- helpers ---

get_worktrees() {
  local main_path="$1"
  git worktree list --porcelain | awk '
    /^worktree/ { path=$2 }
    /^branch/  { branch=$2; gsub(/^refs\/heads\//, "", branch) }
    /^HEAD/    { head=$2 }
    /^$/ {
      if (path != "'"$main_path"'") print branch "\t" path
      else                          print branch " (main)\t" path
      path=branch=head=""
    }' | sort
}

resolve_wt_root() {
  if [ -n "${WT_ROOT:-}" ]; then
    return
  fi
  CONFIG_FILE="$HOME/.wtroot"
  if [ -f "$CONFIG_FILE" ] && [ -s "$CONFIG_FILE" ]; then
    WT_ROOT=$(<"$CONFIG_FILE")
  else
    read -rp "Worktree root directory: " WT_ROOT
    printf '%s' "$WT_ROOT" > "$CONFIG_FILE"
    echo "  Saved to $CONFIG_FILE"
  fi
  WT_ROOT="${WT_ROOT/#\~/$HOME}"
  WT_ROOT="${WT_ROOT%/}"
}

require_fzf() {
  if ! command -v fzf &>/dev/null; then
    err "fzf required. Install: brew install fzf"
    exit 1
  fi
}

# --- main ---
case "${1:-}" in
  "")      cmd_menu ;;
  -h|--help) usage ;;
  add)    shift; cmd_add "$@" ;;
  go)     cmd_go ;;
  ls|list)   cmd_list ;;
  rm|remove) cmd_remove "${2:-}" ;;
  *)      err "unknown command: $1"; usage ;;
esac
