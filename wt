#!/usr/bin/env bash
set -euo pipefail

# --- Catppuccin Mocha palette ---
G=$'\033[38;2;166;227;161m'   # green  (success)
Y=$'\033[38;2;249;226;175m'   # yellow (action)
R=$'\033[38;2;243;139;168m'   # red    (error)
M=$'\033[38;2;203;166;247m'   # mauve  (brand)
S=$'\033[38;2;108;112;134m'   # subtle (dim)
B=$'\033[1m'
N=$'\033[0m'

ok()   { printf '  %s✓%s %s\n' "$G" "$N" "$*"; }
info() { printf '  %s→%s %s\n' "$Y" "$N" "$*"; }
err()  { printf '  %s✗%s %s\n' "$R" "$N" "$*" >&2; }
note() { printf '      %s%s%s\n' "$S" "$*" "$N"; }

# --- fzf theme (Catppuccin Mocha, dark terminal) ---
FZF_OPTS=(
  --height=~70%
  --min-height=15
  --border=rounded
  --border-label=' wt · worktree manager '
  --prompt='❯ '
  --info=inline-right
  --gap=1
  --cycle
  --padding=1,1
  --margin=1,1
  --color=bg+:#313244,bg:#1e1e2e,spinner:#f5c2e7,hl:#f9e2af,hl+:#f9e2af
  --color=fg:#cdd6f4,fg+:#cdd6f4
  --color=border:#585b70,header:#a6adc8,info:#89b4fa,prompt:#cba6f7
  --color=pointer:#f5c2e7,marker:#a6e3a1
  --color=label:#cba6f7,query:#cdd6f4,gutter:#1e1e2e
  --color=preview-fg:#cdd6f4,preview-bg:#1e1e2e,preview-border:#585b70
)

fzf_pick() { fzf --preview-window=down:4:wrap "${FZF_OPTS[@]}" "$@"; }

usage() {
  cat <<EOF
${B}${M}wt${N} — interactive git worktree manager

${B}Usage:${N} wt [command]

${B}Commands:${N}
  (none)    show menu (add / go / remove / list)
  add       add a new worktree interactively
  go        pick a worktree and print its path (for cd)
  ls, list  list worktrees for this repo
  rm [name] remove a worktree (interactive or by partial name)

${B}Options (add):${N}
  -n, --no-env             skip copying .env* files from main checkout
  -c, --copy <glob>        glob pattern to copy from main checkout (default: .env*)
  -b, --branch <name>      create a new branch <name> instead of picking an existing one
                           optional positional: <base> ref to branch from (default: HEAD)
                             e.g.  wt add -b release/v1.2.3 origin/main

${B}Shell integration:${N}
  alias wtgo='cd \$(wt go)'
EOF
  exit 0
}

# --- commands ---

cmd_menu() {
  require_fzf
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "not in a git repository"
    exit 1
  }
  REPO_NAME=$(basename "$REPO_ROOT")
  WORKTREE_COUNT=$(git worktree list | wc -l | tr -d ' ')

  local choice
  choice=$(printf 'Add\tcreate a new worktree\nGo\tjump to existing worktree\nRemove\tdelete a worktree' \
    | fzf --header="  $REPO_NAME  ·  $WORKTREE_COUNT worktrees

  ↑↓ navigate · enter to act · esc to close" \
          --preview='wt ls 2>/dev/null' \
          --preview-window='right:50%:wrap' \
          "${FZF_OPTS[@]}" \
          --gap=0 \
          --no-separator \
    | cut -f1)
  case "$choice" in
    Add)    cmd_add ;;
    Go)     cmd_go ;;
    Remove) cmd_remove "" ;;
  esac
}

cmd_add() {
  local copy_env=true copy_glob=".env*" new_branch="" base=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n|--no-env) copy_env=false; shift ;;
      -c|--copy)   copy_glob="$2"; shift 2 ;;
      -b|--branch) new_branch="$2"; shift 2 ;;
      -*)
        err "unknown option: $1"; usage ;;
      *)
        if [ -n "$new_branch" ] && [ -z "$base" ]; then
          base="$1"; shift
        else
          err "unexpected argument: $1"; usage
        fi
        ;;
    esac
  done

  resolve_wt_root

  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "not in a git repository"
    exit 1
  }
  REPO_NAME=$(basename "$REPO_ROOT")

  local branch is_new=false

  if [ -n "$new_branch" ]; then
    branch="$new_branch"
    is_new=true
  else
    # Interactive: pick from remote branches OR type a new name
    info "syncing with origin…"
    git fetch origin >/dev/null 2>&1 & disown

    local branches
    branches=$(git branch -r --format='%(refname:short)' \
      | sed 's|^origin/||' \
      | grep -v '^HEAD$' \
      | sort -u)

    if [ -z "$branches" ]; then
      err "no remote branches found"
      exit 1
    fi

    require_fzf

    local result query selected
    result=$(printf '✚ New branch…\n%s\n' "$branches" \
      | fzf_pick --print-query -q '' \
                 --header="  $REPO_NAME  ·  pick a branch, or choose 'New branch…' to create one

  enter select · esc cancel" \
                 --preview='
                   if [ {1} = "✚ New branch…" ]; then
                     echo "create a new branch from a base you pick"
                   else
                     git log -1 --oneline origin/{1} --color=always 2>/dev/null || echo "no preview"
                   fi' )
    query=$(echo "$result" | head -1)
    selected=$(echo "$result" | sed -n '2p')

    if [ "$selected" = "✚ New branch…" ] || [ -z "$selected" ] && [ -n "$query" ] && ! grep -qxF "$query" <<< "$branches"; then
      if [ "$selected" = "✚ New branch…" ]; then
        read -rp "  New branch name: " branch
      else
        branch="$query"
      fi
      if [ -z "$branch" ]; then
        err "no branch name given"
        exit 0
      fi
      is_new=true
    elif [ -n "$selected" ] && grep -qxF "$selected" <<< "$branches"; then
      branch="$selected"
    elif [ -n "$query" ] && grep -qxF "$query" <<< "$branches"; then
      branch="$query"
    else
      err "no branch selected"
      exit 0
    fi
  fi

  local WORKTREE_PATH="$WT_ROOT/$REPO_NAME/$branch"

  if [ -d "$WORKTREE_PATH" ]; then
    err "worktree already exists at $WORKTREE_PATH"
    exit 1
  fi

  if $is_new; then
    if [ -z "${base:-}" ]; then
      require_fzf
      local default
      default=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || true)
      # Pick base branch interactively
      base=$(printf '%s' "$branches" \
        | fzf_pick --header="  $REPO_NAME  ·  base branch for $branch

  ↑↓ select base · enter confirm · esc → default" \
                   --preview='git log -1 --oneline origin/{1} --color=always 2>/dev/null || echo "no preview"' \
                   --query="${default:-main}" )
      base=${base:+origin/$base}
      : "${base:=HEAD}"
    fi
    info "creating worktree: $WORKTREE_PATH"
    note "branch: $branch  ·  base: $base"
    git worktree add -b "$branch" "$WORKTREE_PATH" "$base" || exit 1
  else
    info "creating worktree…"
    git worktree add "$WORKTREE_PATH" "$branch"
  fi

  if $copy_env; then
    shopt -s nullglob
    local -a copy_files=("$REPO_ROOT"/$copy_glob)
    if [ ${#copy_files[@]} -gt 0 ]; then
      info "copying $copy_glob files…"
      cp "$REPO_ROOT"/$copy_glob "$WORKTREE_PATH/"
      note "copied ${#copy_files[@]} file(s)"
    fi
  fi

  ok "done: $WORKTREE_PATH"
  printf '%s' "$WORKTREE_PATH" | pbcopy 2>/dev/null \
    && note "path copied to clipboard" \
    || true
}

cmd_go() {
  require_fzf
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "not in a git repository"
    exit 1
  }
  REPO_NAME=$(basename "$REPO_ROOT")
  local path
  path=$(get_worktrees "$REPO_ROOT" \
    | fzf_pick --header="  $REPO_NAME  ·  go to worktree

  enter to print path · esc cancel" \
               --preview='git -C {3} log -1 --oneline --color=always 2>/dev/null || echo "no commits"' \
    | cut -f3)
  [ -n "$path" ] && printf '%s' "$path"
}

cmd_list() {
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "not in a git repository"
    exit 1
  }
  git worktree list --porcelain | awk -v curr="$REPO_ROOT" \
    -v Y="$Y" -v S="$S" -v B="$B" -v N="$N" '
      /^worktree/ { path=$2 }
      /^branch/   { branch=$2; gsub(/^refs\/heads\//, "", branch) }
      /^HEAD/     { head=substr($2,1,7) }
      /^$/ {
        if (path == curr)
          printf "  %s┃%s %s%-30s%s  %s%s%s  %s%s%s\n", Y, N, B, branch, N, S, head, N, S, path, N
        else
          printf "  %s│%s  %-30s  %s%s%s  %s%s%s\n", S, N, branch, S, head, N, S, path, N
        path=branch=head=""
      }'
}

cmd_remove() {
  require_fzf
  local target="$1"

  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "not in a git repository"
    exit 1
  }
  REPO_NAME=$(basename "$REPO_ROOT")

  local worktrees
  worktrees=$(get_worktrees "$REPO_ROOT")

  if [ -z "$worktrees" ]; then
    err "no worktrees to remove"
    exit 0
  fi

  if [ -z "$target" ]; then
    target=$(echo "$worktrees" \
      | fzf_pick --header="  $REPO_NAME  ·  pick a worktree to REMOVE

  ctrl-d to remove · esc to cancel" \
                 --bind='enter:ignore' \
                 --bind='ctrl-d:become(wt rm {3})' \
                 --preview='git -C {3} log -1 --oneline --color=always 2>/dev/null || echo "no commits"' \
      | cut -f3)
  else
    target=$(echo "$worktrees" | grep "$target" | head -1 | cut -f3)
  fi

  if [ -z "$target" ]; then
    err "no worktree selected"
    exit 0
  fi

  info "removing…"
  git worktree remove "$target" || {
    err "remove failed (uncommitted changes?). Use --force to override."
    exit 1
  }
  ok "removed"
}

# --- helpers ---

get_worktrees() {
  local main_path="$1"
  local current_path
  current_path=$(git rev-parse --show-toplevel)
  git worktree list --porcelain | awk -v main="$main_path" -v curr="$current_path" '
    /^worktree/ { path=$2 }
    /^branch/  { branch=$2; gsub(/^refs\/heads\//, "", branch) }
    /^HEAD/    { head=substr($2,1,7) }
    /^$/ {
      prefix=""
      if (path == curr) prefix="● "
      if (path == main) branch = branch " (main)"
      print prefix branch "\t" head "\t" path
      path=branch=head=""
    }'
}

resolve_wt_root() {
  if [ -n "${WT_ROOT:-}" ]; then
    return
  fi
  CONFIG_FILE="$HOME/.wtroot"
  if [ -f "$CONFIG_FILE" ] && [ -s "$CONFIG_FILE" ]; then
    WT_ROOT=$(<"$CONFIG_FILE")
  else
    read -rp "Worktree root directory: " WT_ROOT
    printf '%s' "$WT_ROOT" > "$CONFIG_FILE"
    echo "  Saved to $CONFIG_FILE"
  fi
  WT_ROOT="${WT_ROOT/#\~/$HOME}"
  WT_ROOT="${WT_ROOT%/}"
}

require_fzf() {
  if ! command -v fzf &>/dev/null; then
    err "fzf required. Install: brew install fzf"
    exit 1
  fi
}

# --- main ---
case "${1:-}" in
  "")      cmd_menu ;;
  -h|--help) usage ;;
  add)    shift; cmd_add "$@" ;;
  go)     cmd_go ;;
  ls|list)   cmd_list ;;
  rm|remove) cmd_remove "${2:-}" ;;
  *)      err "unknown command: $1"; usage ;;
esac
